{
  "version": 2,
  "builds": [
    { 
      "src": "Backend/app/main.py", 
      "use": "@vercel/python" 
    },
    { 
      "src": "Frontend/package.json", 
      "use": "@vercel/static-build", 
      "config": { "distDir": "dist" } 
    }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "Backend/app/main.py" },
    { "src": "/api/(.*)", "dest": "Backend/app/main.py" },
    { "src": "/(.*)", "dest": "Frontend/$1", "continue": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "Frontend/index.html" }
  ]
}